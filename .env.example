# ─── Minimal Setup (SQLite + In-Memory) ─────────────────────────
# Just set a secret key and go. No servers needed.
SECRET_KEY=change-me-to-something-random

# ─── Production Setup (PostgreSQL + Redis) ──────────────────────
# Uncomment these for production deployments:
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/keyguard
# REDIS_URL=redis://localhost:6379/0

# ─── Optional Settings ──────────────────────────────────────────
# DEFAULT_RATE_LIMIT_PER_MINUTE=60
# IP_BLOCK_THRESHOLD=100
